<?xml version="1.0" encoding="UTF-8"?>
<alfresco-config>

    <!-- Web Framework -->
    <config evaluator="string-compare" condition="WebFramework">
        <web-framework>
            <autowire>
                <mode>production</mode>
            </autowire>
            <disable-resource-caching>false</disable-resource-caching>
        </web-framework>
    </config>

    <!-- Document Library Config -->
    <config evaluator="string-compare" condition="DocumentLibrary">

        <!-- Custom Types -->
        <types>
            <type name="cm:content">
                <subtype name="cme:contract"/>
            </type>
        </types>

        <!-- Aspects -->
        <aspects>
            <visible>
                <aspect name="cme:contractLifecycle"/>
            </visible>
        </aspects>

        <!-- ACTIONS -->
        <actions>

            <action id="auto-archiver"
                    type="javascript"
                    label="Auto Archive">
                <param name="function">onActionSimpleRepoAction</param>
                <param name="action">auto-archiver</param>
            </action>

            <action id="rename-files-action"
                    type="javascript"
                    label="Rename Files"
                    icon="edit"
                    permission="Write">
                <param name="function">onActionSimpleRepoAction</param>
                <param name="action">rename-files-action</param>
            </action>

            <action id="test-action"
                    type="javascript"
                    label="Test Action"
                    icon="edit"
                    permission="Write">
                <param name="function">onActionSimpleRepoAction</param>
                <param name="action">test-action</param>
            </action>

        </actions>

        <!-- WHERE ACTIONS APPEAR -->
        <actionGroups>
            <actionGroup id="document-browse">
                <action id="auto-archiver"/>
                <action id="rename-files-action"/>
                <action id="test-action"/>
            </actionGroup>

            <actionGroup id="folder-browse">
                <action id="auto-archiver"/>
                <action id="rename-files-action"/>
                <action id="test-action"/>
            </actionGroup>
        </actionGroups>

    </config>

    <!-- Debug Flags -->
    <config replace="true">
        <flags>
            <client-debug>true</client-debug>
            <client-debug-autologging>true</client-debug-autologging>
        </flags>
    </config>

    <!-- Disable CSRF -->
    <config evaluator="string-compare" condition="CSRFPolicy" replace="true">
        <filter/>
    </config>

    <!-- Remote Endpoints -->
    <config evaluator="string-compare" condition="Remote">
        <remote>

            <endpoint>
                <id>alfresco-noauth</id>
                <connector-id>alfresco</connector-id>
                <endpoint-url>http://${acs.host}:8080/alfresco/s</endpoint-url>
                <identity>none</identity>
            </endpoint>

            <endpoint>
                <id>alfresco</id>
                <connector-id>alfresco</connector-id>
                <endpoint-url>http://${acs.host}:8080/alfresco/s</endpoint-url>
                <identity>user</identity>
            </endpoint>

            <endpoint>
                <id>alfresco-api</id>
                <parent-id>alfresco</parent-id>
                <connector-id>alfresco</connector-id>
                <endpoint-url>http://${acs.host}:8080/alfresco/api</endpoint-url>
                <identity>user</identity>
            </endpoint>

        </remote>
    </config>

</alfresco-config>